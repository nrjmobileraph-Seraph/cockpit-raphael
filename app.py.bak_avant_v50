        pts={}
        for age in [50,56,60,64,70,75,80,85,90,92]:
            n=age-50
            if age<=64: v=C0*P(n)-pp1*A(n)
            elif age<=75: v=C64*P(age-64)-rail_s*A(age-64)
            else: v=C75*P(age-75)-(rail_s-rvd+ehpad)*A(age-75)
            pts[age]=round(v,0)
        return round(C92,0),pts
